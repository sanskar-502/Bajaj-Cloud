CHUNK_SIZE=1000
CHUNK_OVERLAP=200
TOP_K_RESULTS=5
SIMILARITY_THRESHOLD=0.5
MAX_FILE_SIZE=50

API_HOST=0.0.0.0
API_PORT=8000
UPLOAD_DIR=uploads
VECTOR_STORE_DIR=vector_store
LOG_LEVEL=INFO

HACKRX_TOKEN=replace_with_secure_token
